+     Unless required by applicable law or agreed to in writing, software
+     distributed under the License is distributed on an "AS IS" BASIS,
+     WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.
+     See the License for the specific language governing permissions and
+     limitations under the License.
+-->
+<!--
+     Framework Compatibility Matrix for FCM version 5 (Android R / API level 30).
+     AOSP-17 dropped the R (and S) framework matrices (only ships 7+), but this device's
+     vendor is frozen at Android 11 (device manifest target-level="5"), so checkvintf needs
+     a framework matrix at FCM version 5. The only android.* HAL the device manifest declares
+     that is absent from the in-tree matrices (>=7) is the deprecated health@2.1 HIDL HAL;
+     it is listed here (optional) so checkvintf finds it. Add further deprecated HALs here if
+     checkvintf reports more missing.
+
+     KERNEL: checkvintf enforces that the runtime kernel version matches a <kernel> entry in the
+     matrix at the device's target FCM level (5), independent of kernel_configs. The device runs
+     kernel 4.9; AOSP-17 pruned the kernel_config_r_* modules (R-era config fragments), so we
+     declare a minimal <kernel version="4.9.0"/> with NO <config> children — it satisfies the
+     version match (runtime 4.9.x >= 4.9.0) with zero config requirements to enforce. Without
+     this entry, checkvintf fails: "No kernel entry found for kernel version 4.9 at FCM 5".
+-->
+<compatibility-matrix version="1.0" type="framework" level="5">
+    <hal format="hidl" optional="true">
+        <name>android.hardware.health</name>
+        <version>2.1</version>
+        <interface>
+            <name>IHealth</name>
+            <instance>default</instance>
+        </interface>
+    </hal>
+    <kernel version="4.9.0"/>
+</compatibility-matrix>
