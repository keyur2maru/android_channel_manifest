+++ b/src/gallium/auxiliary/pipe-loader/pipe_loader_drm.c
@@ -138,8 +138,16 @@ pipe_loader_drm_probe_fd_nodup(struct pipe_loader_device **dev, int fd, bool zin
       ddev->base.driver_name = strdup("zink");
    else
       ddev->base.driver_name = loader_get_driver_for_fd(fd);
-   if (!ddev->base.driver_name)
-      goto fail;
+   if (!ddev->base.driver_name) {
+#ifdef HAVE_FREEDRENO_KGSL
+      /* channel A17: /dev/kgsl-3d0 is not a DRM node, so drmGetVersion-based
+       * detection returns NULL. Assume the freedreno driver -- its DRM
+       * descriptor carries a "kgsl" alias for exactly this case. */
+      ddev->base.driver_name = strdup("kgsl");
+#endif
+      if (!ddev->base.driver_name)
+         goto fail;
+   }
 
    /* For the closed source AMD OpenGL driver, we want libgbm to load
     * "amdgpu_dri.so", but we want Gallium multimedia drivers to load
diff --git a/src/gallium/drivers/freedreno/freedreno_screen.c b/src/gallium/drivers/freedreno/freedreno_screen.c
index 4b128d4..a9eb481 100644
--- a/src/gallium/drivers/freedreno/freedreno_screen.c
+++ b/src/gallium/drivers/freedreno/freedreno_screen.c
@@ -373,6 +373,15 @@ fd_init_screen_caps(struct fd_screen *screen)
 
    u_init_pipe_screen_caps(&screen->base, 1);
 
+   /* channel A17: u_init_pipe_screen_caps() derives caps->dmabuf from
+    * drmGetCap(DRM_CAP_PRIME), which fails on the kgsl backend because
+    * /dev/kgsl-3d0 is not a DRM device (returns 0 -> dmabuf import disabled,
+    * so EGL_NATIVE_BUFFER_ANDROID / dri2_from_dma_bufs is rejected and
+    * SurfaceFlinger cannot map any gralloc buffer as a texture). The freedreno
+    * bo layer supports dma-buf import (bo_from_dmabuf / GPUOBJ_IMPORT) and
+    * export (fd_bo dmabuf) on every backend, so advertise both unconditionally. */
+   caps->dmabuf = DRM_PRIME_CAP_IMPORT | DRM_PRIME_CAP_EXPORT;
+
    /* this is probably not totally correct.. but it's a start: */
 
    /* Supported features (boolean caps). */
