From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Keyur Maru <kd2maru@gmail.com>
Date: Mon, 13 Jul 2026 02:15:47 -0700
Subject: [PATCH 3/4] egl/android, u_gralloc, gallium: wire up the KGSL
 (non-DRM) buffer path

With the KGSL winsys in place the GPU can be driven, but nothing can reach it:
every layer above assumes the GPU fd is a DRM node.  /dev/kgsl-3d0 is not, so
DRM enumeration finds no device, drmGetVersion() and drmGetCap() both fail on
the fd, and EGL comes up with zero configs -- SurfaceFlinger's chooseEglConfig()
then aborts and nothing renders.  Teach the loaders and the gralloc import path
about a GPU that has no DRM node.

platform_android: when DRM enumeration finds nothing, open /dev/kgsl-3d0
directly and force the freedreno ("msm") gallium driver; fd_device_new() detects
KGSL when drmGetVersion() fails on the fd.  Only on the hardware path -- for a
software/swrast request this branch must be skipped, or dri2_create_screen()
picks DRI_SCREEN_SWRAST while droid_probe_device() installs an image-loader
extension list with no __DRI_SWRAST_LOADER, and drisw_init_screen() dereferences
a NULL swrast_loader.  Likewise, dri2_setup_device()'s render-capability probe
cannot succeed on a non-DRM fd, so fall back to the software EGLDevice (which is
only consumed by EGL_EXT_device_query) rather than failing init outright.  Do not
overwrite a driver_name that was already pinned to "msm" for this path.

pipe_loader_drm: loader_get_driver_for_fd() is drmGetVersion()-based and returns
NULL for the KGSL fd; assume the freedreno driver instead of failing the probe.

freedreno_screen: u_init_pipe_screen_caps() derives caps->dmabuf from
drmGetCap(DRM_CAP_PRIME), which fails on a non-DRM fd, leaving dma-buf import
disabled -- so dri2_from_dma_bufs() rejects every EGL_NATIVE_BUFFER_ANDROID and
SurfaceFlinger cannot bind a single gralloc buffer as a texture.  The freedreno
bo layer supports dma-buf import and export on every backend, so advertise both
unconditionally.

u_gralloc: add the QCOM/CAF Venus video-decoder HAL formats emitted by msm8953.
They are absent from <hardware/gralloc.h> (they live in the display HAL's
QtiGrallocDefs.h), so they are defined by value here and mapped to their NV12 /
NV21 fourccs; they are semi-planar 4:2:0, hence chroma_step 2.  Without this a
decoded video buffer has no fourcc and cannot be imported at all.
---
 src/egl/drivers/dri2/platform_android.c       | 85 ++++++++++++++++++-
 .../auxiliary/pipe-loader/pipe_loader_drm.c   | 12 ++-
 .../drivers/freedreno/freedreno_screen.c      |  9 ++
 src/gallium/frontends/dri/dri2.c              | 12 ++-
 src/util/u_gralloc/u_gralloc_internal.c       | 31 +++++++
 5 files changed, 143 insertions(+), 6 deletions(-)

diff --git a/src/egl/drivers/dri2/platform_android.c b/src/egl/drivers/dri2/platform_android.c
index 7db9f6b..0c33fab 100644
--- a/src/egl/drivers/dri2/platform_android.c
+++ b/src/egl/drivers/dri2/platform_android.c
@@ -83,15 +83,29 @@ droid_create_image_from_native_buffer(_EGLDisplay *disp,
    struct dri_image *img = NULL;
 
    if (u_gralloc_get_buffer_basic_info(dri2_dpy->gralloc, &gr_handle,
-                                       &buf_info))
+                                       &buf_info)) {
+      _eglLog(_EGL_WARNING, "channel img: u_gralloc_get_buffer_basic_info FAILED "
+              "(hal_format=0x%x pixel_stride=%d)", buf->format, buf->stride);
       return NULL;
+   }
 
    if (u_gralloc_get_buffer_color_info(dri2_dpy->gralloc, &gr_handle,
-                                       &color_info))
+                                       &color_info)) {
+      _eglLog(_EGL_WARNING, "channel img: u_gralloc_get_buffer_color_info FAILED");
       return NULL;
+   }
+
+   _eglLog(_EGL_DEBUG, "channel img: %dx%d fourcc=0x%x mod=0x%llx planes=%d "
+           "stride0=%d off0=%d fd0=%d", buf->width, buf->height,
+           buf_info.drm_fourcc, (unsigned long long)buf_info.modifier,
+           buf_info.num_planes, buf_info.strides[0], buf_info.offsets[0],
+           buf_info.fds[0]);
 
    img = droid_create_image_from_buffer_info(dri2_dpy, buf->width, buf->height,
                                              &buf_info, &color_info, priv);
+   if (!img)
+      _eglLog(_EGL_WARNING, "channel img: dri2_from_dma_bufs FAILED (mod=0x%llx), "
+              "retrying with MOD_INVALID", (unsigned long long)buf_info.modifier);
 
    if (!img) {
       /* If dri driver is gallium virgl, real modifier info queried back from
@@ -815,6 +829,22 @@ droid_add_configs_for_visuals(_EGLDisplay *disp)
     * (chadversary) testing on Android Nougat, this was good enough to pacify
     * the buggy clients.
     */
+   /* channel A17 diag: dump the driver-provided config color formats so we can
+    * see why no visual matches (e.g. array R8G8B8A8 vs packed RGBA8888). */
+   {
+      int nconf = 0;
+      for (int j = 0; dri2_dpy->driver_configs && dri2_dpy->driver_configs[j]; j++) {
+         const struct gl_config *gc = (const struct gl_config *) dri2_dpy->driver_configs[j];
+         if (nconf < 24)
+            _eglLog(_EGL_DEBUG, "channel cfg[%d] color_format=%s(0x%x) linear=%s",
+                    j, util_format_name(gc->color_format), gc->color_format,
+                    util_format_name(util_format_linear(gc->color_format)));
+         nconf++;
+      }
+      _eglLog(_EGL_DEBUG, "channel: %d driver_configs total; want RGBA8888=0x%x RGBX8888=0x%x B5G6R5=0x%x",
+              nconf, PIPE_FORMAT_RGBA8888_UNORM, PIPE_FORMAT_RGBX8888_UNORM, PIPE_FORMAT_B5G6R5_UNORM);
+   }
+
    bool has_rgba = false;
    for (int i = 0; i < ARRAY_SIZE(visuals); i++) {
       /* Only enable BGRA configs when RGBA is not available. BGRA configs are
@@ -1021,7 +1051,9 @@ droid_load_driver(_EGLDisplay *disp, bool swrast)
 
    if (disp->Options.Zink)
       dri2_dpy->driver_name = strdup("zink");
-   else
+   else if (dri2_dpy->driver_name == NULL)
+      /* channel A17: may be pre-set to "msm" for the kgsl (non-DRM) path;
+       * only auto-detect from the fd when it's a real DRM device. */
       dri2_dpy->driver_name = loader_get_driver_for_fd(dri2_dpy->fd_render_gpu);
    if (dri2_dpy->driver_name == NULL)
       return false;
@@ -1163,6 +1195,37 @@ droid_open_device(_EGLDisplay *disp, bool swrast)
    }
 
    if (dri2_dpy->fd_render_gpu < 0) {
+#ifdef HAVE_FREEDRENO_KGSL
+      /* channel A17: the downstream Adreno "kgsl" GPU driver exposes NO DRM
+       * node, so the DRM enumeration above finds nothing. Open /dev/kgsl-3d0
+       * directly and force the freedreno ("msm") gallium driver; fd_device_new()
+       * detects kgsl when drmGetVersion() fails on this fd.
+       *
+       * Only for the HARDWARE path: when software (ForceSoftware/swrast) is
+       * requested we must NOT take this branch. dri2_detect_swrast_kopper() would
+       * flag swrast=true and dri2_create_screen() would pick DRI_SCREEN_SWRAST,
+       * but droid_probe_device() installs the image-loader extension list which
+       * has no __DRI_SWRAST_LOADER, so drisw_init_screen() derefs a NULL
+       * screen->swrast_loader (crash, fault addr 0x8). Falling through returns
+       * EGL_FALSE and lets dri2_initialize_android() run its proper swrast path
+       * (driver_name="swrast" + droid_swrast_image_loader_extensions). */
+      if (!swrast) {
+         dri2_dpy->fd_render_gpu = loader_open_device("/dev/kgsl-3d0");
+         if (dri2_dpy->fd_render_gpu >= 0) {
+            free(dri2_dpy->driver_name);
+            dri2_dpy->driver_name = strdup("msm");
+            _eglLog(_EGL_WARNING, "kgsl: /dev/kgsl-3d0 opened (fd %d), creating hw screen",
+                    dri2_dpy->fd_render_gpu);
+            if (droid_probe_device(disp, false))
+               return EGL_TRUE;
+            _eglLog(_EGL_WARNING, "kgsl: /dev/kgsl-3d0 opened but screen create failed");
+            close(dri2_dpy->fd_render_gpu);
+            dri2_dpy->fd_render_gpu = -1;
+         } else {
+            _eglLog(_EGL_WARNING, "kgsl: failed to open /dev/kgsl-3d0");
+         }
+      }
+#endif
       _eglLog(_EGL_WARNING, "Failed to open %s DRM device",
               vendor_name ? "desired" : "any");
       return EGL_FALSE;
@@ -1213,8 +1276,24 @@ dri2_initialize_android(_EGLDisplay *disp)
    dri2_dpy->fd_display_gpu = dri2_dpy->fd_render_gpu;
 
    if (!dri2_dpy->pure_swrast && !dri2_setup_device(disp, false)) {
+#ifdef HAVE_FREEDRENO_KGSL
+      /* channel A17: /dev/kgsl-3d0 is NOT a DRM render node, so
+       * dri2_setup_device()'s render-capability probe fails and
+       * dri_query_compatible_render_only_device_fd() finds no companion DRM
+       * node (returns -1). disp->Device is only consumed by EGL_EXT_device_query,
+       * so fall back to the software-device path (render_fd = -1) to obtain a
+       * valid _EGLDevice instead of aborting init (which would leave zero
+       * EGLConfigs and make SurfaceFlinger's chooseEglConfig abort). */
+      _eglLog(_EGL_WARNING,
+              "kgsl: dri2_setup_device(hw) failed (non-DRM fd); using sw EGLDevice");
+      if (!dri2_setup_device(disp, EGL_TRUE)) {
+         err = "DRI2: failed to setup EGLDevice";
+         goto cleanup;
+      }
+#else
       err = "DRI2: failed to setup EGLDevice";
       goto cleanup;
+#endif
    }
 
    dri2_setup_screen(disp);
diff --git a/src/gallium/auxiliary/pipe-loader/pipe_loader_drm.c b/src/gallium/auxiliary/pipe-loader/pipe_loader_drm.c
