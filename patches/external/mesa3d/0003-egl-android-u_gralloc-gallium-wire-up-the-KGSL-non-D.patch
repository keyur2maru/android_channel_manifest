diff --git a/src/util/u_gralloc/u_gralloc_internal.c b/src/util/u_gralloc/u_gralloc_internal.c
index c645202..11beaa6 100644
--- a/src/util/u_gralloc/u_gralloc_internal.c
+++ b/src/util/u_gralloc/u_gralloc_internal.c
@@ -14,6 +14,30 @@
 #include "drm-uapi/drm_fourcc.h"
 #include "util/log.h"
 
+/*
+ * QCOM/CAF vendor HAL pixel formats emitted by the msm8953 (Venus) video
+ * decoder. These are NOT present in <hardware/gralloc.h>; the canonical
+ * definitions live in the display HAL's QtiGrallocDefs.h. The "Venus" family
+ * is semi-planar 4:2:0 (a Y plane followed by an interleaved Cb/Cr plane, i.e.
+ * NV12/NV21) with Venus stride/scanline alignment (Y: stride align 128,
+ * scanline align 32; UV: stride align 128, scanline align 16). When UBWC is
+ * disabled (channel: vendor.gralloc.disable_ubwc=1) the _UBWC variant is
+ * allocated as plain linear NV12, which a5xx/freedreno can sample once we
+ * route it through the YUV plane-info path below. We only look these up by
+ * value, so we tolerate a stale <hardware/gralloc.h> that lacks them. */
+#ifndef HAL_PIXEL_FORMAT_NV21_ENCODEABLE
+#define HAL_PIXEL_FORMAT_NV21_ENCODEABLE        0x7FA30C00 /* NV21, Venus aligned */
+#endif
+#ifndef HAL_PIXEL_FORMAT_YCbCr_420_SP_VENUS
+#define HAL_PIXEL_FORMAT_YCbCr_420_SP_VENUS     0x7FA30C04 /* NV12, Venus aligned */
+#endif
+#ifndef HAL_PIXEL_FORMAT_YCbCr_420_SP_VENUS_UBWC
+#define HAL_PIXEL_FORMAT_YCbCr_420_SP_VENUS_UBWC 0x7FA30C06 /* NV12 (UBWC when compressed) */
+#endif
+#ifndef HAL_PIXEL_FORMAT_YCrCb_420_SP_VENUS
+#define HAL_PIXEL_FORMAT_YCrCb_420_SP_VENUS     0x114      /* NV21, Venus aligned */
+#endif
+
 enum chroma_order {
    YCbCr,
    YCrCb,
@@ -37,6 +61,13 @@ static const struct droid_yuv_format droid_yuv_formats[] = {
    {HAL_PIXEL_FORMAT_YCbCr_420_888, YCbCr, 1, DRM_FORMAT_YUV420},
    {HAL_PIXEL_FORMAT_YCbCr_420_888, YCrCb, 1, DRM_FORMAT_YVU420},
    {HAL_PIXEL_FORMAT_YV12, YCrCb, 1, DRM_FORMAT_YVU420},
+   /* QCOM Venus video-decoder formats. Semi-planar => chroma_step 2. The exact
+    * plane offsets/strides come from the gralloc's lock_ycbcr / perform
+    * GET_YUV_PLANE_INFO (Venus alignment), so we only need the fourcc here. */
+   {HAL_PIXEL_FORMAT_YCbCr_420_SP_VENUS, YCbCr, 2, DRM_FORMAT_NV12},
+   {HAL_PIXEL_FORMAT_YCbCr_420_SP_VENUS_UBWC, YCbCr, 2, DRM_FORMAT_NV12},
+   {HAL_PIXEL_FORMAT_NV21_ENCODEABLE, YCrCb, 2, DRM_FORMAT_NV21},
+   {HAL_PIXEL_FORMAT_YCrCb_420_SP_VENUS, YCrCb, 2, DRM_FORMAT_NV21},
    /* HACK: See droid_create_image_from_prime_fds() and
     * https://issuetracker.google.com/32077885. */
    {HAL_PIXEL_FORMAT_IMPLEMENTATION_DEFINED, YCbCr, 2, DRM_FORMAT_NV12},
