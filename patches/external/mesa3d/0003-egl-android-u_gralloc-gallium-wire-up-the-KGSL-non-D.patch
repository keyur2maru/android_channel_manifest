+   mesa_logd("channel dma: fourcc=0x%x mod=0x%llx map=%p expected_num_fds=%d num_fds=%d",
+             fourcc, (unsigned long long)modifier, (void *)map, expected_num_fds, num_fds);
    if (!map || expected_num_fds == 0) {
       err = __DRI_IMAGE_ERROR_BAD_MATCH;
       goto exit;
@@ -1469,6 +1472,8 @@ dri2_from_dma_bufs(struct dri_screen *screen,
    img = dri_create_image_from_winsys(screen, width, height, map,
                                        num_fds, whandles, flags,
                                        loaderPrivate);
+   mesa_logd("channel dma: dri_create_image_from_winsys -> %p (pipe_format=0x%x)",
+             (void *)img, map->pipe_format);
    if (img == NULL) {
       err = __DRI_IMAGE_ERROR_BAD_ALLOC;
       goto exit;
@@ -1758,8 +1763,13 @@ dri2_init_screen(struct dri_screen *screen, bool driver_name_is_inferred)
    screen->can_share_buffer = true;
 
 #ifdef HAVE_LIBDRM
-   if (pipe_loader_drm_probe_fd(&screen->dev, screen->fd, false))
