From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Keyur Maru <kd2maru@gmail.com>
Date: Fri, 10 Jul 2026 19:13:36 -0700
Subject: [PATCH] Restore the android.frameworks.displayservice@1.0 HIDL
 interface

AOSP-17 dropped this interface, but the proprietary camera.msm8953 blob
(vendor/motorola/channel) has a DT_NEEDED on the @1.0 32-bit variant. Re-add
the HIDL definition so the vendor camera HAL links.

---
 displayservice/1.0/Android.bp                | 22 +++++++
 displayservice/1.0/IDisplayEventReceiver.hal | 66 ++++++++++++++++++++
 displayservice/1.0/IDisplayService.hal       | 27 ++++++++
 displayservice/1.0/IEventCallback.hal        | 30 +++++++++
 displayservice/1.0/types.hal                 | 22 +++++++
 5 files changed, 167 insertions(+)
 create mode 100644 displayservice/1.0/Android.bp
 create mode 100644 displayservice/1.0/IDisplayEventReceiver.hal
 create mode 100644 displayservice/1.0/IDisplayService.hal
 create mode 100644 displayservice/1.0/IEventCallback.hal
 create mode 100644 displayservice/1.0/types.hal

diff --git a/displayservice/1.0/Android.bp b/displayservice/1.0/Android.bp
new file mode 100644
index 0000000..0a60af0
--- /dev/null
+++ b/displayservice/1.0/Android.bp
@@ -0,0 +1,22 @@
+// This file is autogenerated by hidl-gen -Landroidbp.
+
+package {
+    default_applicable_licenses: ["Android-Apache-2.0"],
+}
+
+hidl_interface {
+    name: "android.frameworks.displayservice@1.0",
+    // channel A17: hidl_interface is vendor_available by default; the /vendor 32-bit variant is
+    // pulled in by camera.msm8953's shared_libs dep (vendor/motorola/channel/Android.bp).
+    root: "android.frameworks",
+    srcs: [
+        "types.hal",
+        "IDisplayEventReceiver.hal",
+        "IDisplayService.hal",
+        "IEventCallback.hal",
+    ],
+    interfaces: [
+        "android.hidl.base@1.0",
+    ],
+    gen_java: false,
+}
diff --git a/displayservice/1.0/IDisplayEventReceiver.hal b/displayservice/1.0/IDisplayEventReceiver.hal
new file mode 100644
index 0000000..5ff0d44
--- /dev/null
+++ b/displayservice/1.0/IDisplayEventReceiver.hal
@@ -0,0 +1,66 @@
+/*
