From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Keyur Maru <kd2maru@gmail.com>
Date: Fri, 10 Jul 2026 19:12:27 -0700
Subject: [PATCH 1/2] libs/ui: force the legacy gralloc mapper on gralloc2
 devices

This msm8953 device ships the gralloc2 / mapper@2.1 HAL (old Adreno blob) and
has no mapper4. android_get_device_api_level() reports >=36 (date-based board
api_level), so requireMapper4() would force a mapper4-only path and abort
("gralloc-mapper is missing"). Return false so GraphicBufferMapper falls
through to Gralloc2Mapper.

Change-Id: Ifd71674a4b5268bb387db9eceb01f1cb47faf553
---
 libs/ui/GraphicBufferMapper.cpp | 7 ++++++-
 1 file changed, 6 insertions(+), 1 deletion(-)

diff --git a/libs/ui/GraphicBufferMapper.cpp b/libs/ui/GraphicBufferMapper.cpp
index 91c760eac702d..33219935e13ac 100644
--- a/libs/ui/GraphicBufferMapper.cpp
+++ b/libs/ui/GraphicBufferMapper.cpp
@@ -54,7 +54,12 @@ using LockResult = GraphicBufferMapper::LockResult;
 ANDROID_SINGLETON_STATIC_INSTANCE( GraphicBufferMapper )
 
 static bool requireMapper4() {
-    return android_get_device_api_level() >= 36 && flags::require_gralloc4_or_newer();
+    // channel A17 bring-up: this msm8953 device is the gralloc2/mapper@2.1 era (old
+    // Adreno blob) and has no gralloc4/mapper4 HAL. android_get_device_api_level()
+    // reports >=36 here (date-based board api_level), which would force mapper4-only and
+    // make GraphicBufferMapper abort ("gralloc-mapper is missing") instead of falling
+    // through to Gralloc2Mapper. Force the legacy path so our @2.1 mapper loads.
+    return false;
 }
 
 void GraphicBufferMapper::preloadHal() {
